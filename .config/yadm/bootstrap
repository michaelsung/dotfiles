#!/usr/bin/env bash
set -euo pipefail

echo "=== Claude Code bootstrap ==="

# Official marketplace (idempotent)
echo "--- Official marketplace ---"
claude plugin marketplace add anthropics/claude-plugins-official 2>/dev/null \
  || echo "Already configured"

# Safety-net community plugin
# NOTE: Verify the exact marketplace repo name at https://github.com/kenryu42/claude-code-safety-net
echo "--- Safety-net plugin ---"
claude plugin marketplace add kenryu42/cc-marketplace 2>/dev/null || true
claude plugin install safety-net@cc-marketplace 2>/dev/null \
  || echo "safety-net already installed or marketplace name needs verification — check https://github.com/kenryu42/claude-code-safety-net"

# Official plugins
echo "--- Official plugins ---"
for plugin in "claude-md-management" "hookify"; do
  claude plugin install "${plugin}@claude-plugins-official" 2>/dev/null \
    || echo "${plugin} already installed"
done

# Playwright MCP (user scope — stored in ~/.claude.json, not yadm-tracked)
echo "--- Playwright MCP ---"
if ! claude mcp list 2>/dev/null | grep -q "playwright"; then
  claude mcp add playwright npx @playwright/mcp@latest --scope user
  echo "Playwright MCP added"
else
  echo "Playwright MCP already configured"
fi

echo ""
echo "=== Bootstrap complete ==="
echo "Run 'claude plugin list' and 'claude mcp list' to verify."
echo ""
echo "Ensure ~/.zshrc includes safety-net mode vars:"
echo "  export SAFETY_NET_STRICT=1"
echo "  export SAFETY_NET_PARANOID_RM=1"
